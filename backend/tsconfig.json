//TypeScript configuration for the backend project



{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "outDir":          "./dist",
    "rootDir":         "./src",
    "strict":          true,
    "esModuleInterop": true,
    "skipLibCheck":    true,
    "types": ["node"],
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}



